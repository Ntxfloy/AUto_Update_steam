# Скопируй в .env и заполни реальными значениями

# Bearer-токен для авторизации API запросов
STEAM_API_KEY=your-secret-api-key-here

# AES-256 ключ шифрования паролей (hex 64 символа ИЛИ base64 44 символа)
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
STEAM_ENC_KEY=your-32-byte-hex-or-base64-key-here

# Путь к SQLite БД (опционально, по умолчанию steam_club.db)
DB_PATH=steam_club.db
